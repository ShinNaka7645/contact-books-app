<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>パスワードリセット - 連絡帳アプリ</title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <% if (errors.length > 0) { %>
      <ul class="errors">
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }); %>
      </ul>
    <% } %>

    <form action="/reset-password" method="POST">
      <h2>パスワードリセット</h2> 

      <p>ユーザーID <small>(半角英数字・記号)</small></p>
      <input type="text" name="user_id" />

      <p>新しいパスワード <small>(20文字以内)</small></p>
      <input type="password" name="new_password" />

      <input type="submit" value="パスワード再発行" />
      
      <p style="text-align: center; margin-top: 20px;">
        <a href="/login" style="color: #718096; text-decoration: none; font-size: 0.8rem;">ログイン画面へ戻る</a>
      </p>
      <p style="text-align: center; margin-top: 20px;">
        <a href="/" style="color: #718096; text-decoration: none; font-size: 0.8rem;">トップへ戻る</a>
      </p>
    </form>
  </body>
</html>