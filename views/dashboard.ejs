<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>記入画面 - 連絡帳アプリ</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="dashboard-body">
  <% if(user.role === "学年主任") { %>
    <h1><%= user.grade %>年主任 <%= user.name %></h1>
  <% } else if(user.role === "担任") { %>
    <h1><%= user.grade %>年<%= user.cls %>組担任 <%= user.name %></h1>
  <% } else { %>
    <h1><%= user.grade %>年<%= user.cls %>組 <%= user.name %></h1>
  <% } %>

  <div class="calendar-section">
    <label>日付を選択：</label>
    <input type="date" value="<%= targetDate %>" onchange="location.href='/dashboard?date=' + this.value">
  </div>

  <% if (user.role === '生徒') { %>
    <% if(isToday){ %>
      <form action="/save-contact" method="POST">
        <p>体調</p>
        <select name="health">
          <option>1: 悪い</option>
          <option>2: やや悪い</option>
          <option selected>3: ふつう</option> <!-- デフォルトで選択される -->
          <option>4: 良い</option>
          <option>5: とても良い</option>
        </select>
        <p>メンタル</p>
        <select name="mental">
          <option>1: 悪い</option>
          <option>2: やや悪い</option>
          <option selected>3: ふつう</option> <!-- デフォルトで選択される -->
          <option>4: 良い</option>
          <option>5: とても良い</option>
        </select>
        <p>今日の振り返り・相談内容</p>
        <textarea name="content"></textarea>
        <input type="submit" value="保存する">
      </form>
    <% } %>
  <% } %>

  <div class="contact-list">
    <h2><%= targetDate %> の連絡一覧</h2>
    <a href="/history" style="float: right;">過去の提出履歴</a>
    <% if (logs.length > 0) { %>
      <% if(user.role === '学年主任') { %>
          <!-- 学年主任は生徒の学年・クラスも参照できる -->
          <% logs.forEach(log => { %>
              <div class="log-item">
                <strong>【<%= log.grade %>年<%= log.cls %>組 <%= log.name %> さん】</strong>
                <p><strong>◎ 体調:</strong> <%= log.health %></p>
                <p><strong>◎ メンタル:</strong> <%= log.mental %></p>
                <strong>◎ 今日の振り返り・相談内容</strong>
                <p><%= log.content %></p>
              </div>
          <% }) %>
      <% } else { %>
        <!-- 生徒・担任は生徒名だけ参照可能 -->
        <% logs.forEach(log => { %>
          <div class="log-item">
            <strong>【<%= log.name %> さん】</strong>
            <p><strong>◎ 体調:</strong> <%= log.health %></p>
            <p><strong>◎ メンタル:</strong> <%= log.mental %></p>
            <strong>◎ 今日の振り返り・相談内容</strong>
            <p class="message-content"><%= log.content %></p>

            <div class="status-area">
              <% if (log.is_read) { %>
                <div style="display: flex; align-items: center; gap: 10px;">
                  <span style="color: orange; font-weight: bold;">[済] 💮 担任が確認しました</span>
                  
                  <% if (user.role === "担任") { %>
                    <form action="/unread-contact/<%= log.id %>" method="POST" style="margin: 0;">
                      <button type="submit" class="cancel-btn">（取消）</button>
                    </form>
                  <% } %>
                </div>

              <% } else if (user.role === "担任") { %>
                <div class="button-container">
                <form action="/read-contact/<%= log.id %>" method="POST">
                  <button type="submit" class="stamp-btn">確認（いいね！）</button>
                </form>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>  
      <% } %>
    <% } else { %>
        <p>連絡事項はありません。</p>
    <% } %>
  </div>

  <p><a href="/logout">ログアウト</a></p>
</body>
</html>